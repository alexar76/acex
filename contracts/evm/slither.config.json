{
  "filter_paths": "(lib/|test/|script/)",
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_remaps": [
    "@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/"
  ],
  "solc_args": "--optimize --optimize-runs 200",
  "disable_color": false,
  "json": "slither-report.json"
}
